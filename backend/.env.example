# FastAPI
APP_NAME=BiasLens Orchestration API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=
S3_KEY_PREFIX=datasets
PRESIGNED_EXPIRY_SECONDS=900

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Colab / Worker Tunnel
COLAB_TRIGGER_URL=
COLAB_SHARED_SECRET=
COLAB_REQUEST_TIMEOUT_SECONDS=20
BACKEND_PUBLIC_URL=http://localhost:8000

# Fallback user profile for MVP auth-less mode
DEFAULT_USER_ID=demo-user
DEFAULT_USER_EMAIL=demo@biaslens.ai
DEFAULT_USER_NAME=BiasLens Demo User
DEFAULT_USER_ROLE=researcher
