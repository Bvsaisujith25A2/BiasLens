# BiasLens Colab Worker Environment Variables
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git - it contains secrets

# ========== BACKEND CONFIGURATION ==========
# Public HTTPS URL of your backend server (where BiasLens API runs)
# Used for job status callbacks and health checks
BACKEND_CALLBACK_URL=https://3.110.87.92.nip.io/api/v1/webhooks/colab/job-status
BACKEND_HEALTH_URL=https://3.110.87.92.nip.io/api/v1/health

# Shared secret for authenticating webhook callbacks from Colab to backend
# Must match COLAB_SHARED_SECRET in backend .env
COLAB_SHARED_SECRET=your-colab-worker-secret-key

# ========== AWS S3 CONFIGURATION ==========
# AWS region where your S3 bucket is located
AWS_REGION=us-east-1

# AWS IAM credentials for S3 access
# Can be from IAM user or temporary credentials
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJal...

# Optional: AWS session token (for temporary credentials from STS)
# Leave empty if using permanent IAM credentials
AWS_SESSION_TOKEN=

# S3 bucket name where datasets and heatmaps are stored
S3_BUCKET_NAME=your-biaslens-bucket

# ========== NGROK CONFIGURATION ==========
# ngrok authentication token for exposing worker to public internet
# Get from: https://dashboard.ngrok.com/auth/your-authtoken
# With authtoken, you can use permanent domain reservations
NGROK_AUTHTOKEN=your-ngrok-authtoken

# ========== COLAB WORKER BINDING ==========
# Host to bind FastAPI server (0.0.0.0 = all interfaces)
COLAB_WORKER_HOST=0.0.0.0

# Port for FastAPI worker service (must not conflict with other services)
COLAB_WORKER_PORT=8787

# ========== OPTIONAL: DATASET CONFIGURATION ==========
# S3 path prefix for dataset downloads (with trailing slash)
# Example: s3://my-bucket/datasets/
DATASET_S3_PREFIX=s3://your-bucket/datasets/

# Local directory in Colab for temporary dataset storage
# Colab gives ~100GB free storage; adjust based on dataset size
COLAB_WORK_DIR=/content/biaslens_work

# ========== OPTIONAL: MODEL CONFIGURATION ==========
# Number of epochs for training proxy model
MODEL_EPOCHS=5

# Batch size for training (increase if you have more GPU memory)
BATCH_SIZE=32

# Learning rate for Adam optimizer
LEARNING_RATE=0.0001

# ========== OPTIONAL: ANALYSIS CONFIGURATION ==========
# Subgroup accuracy disparity threshold (e.g., 15% = 0.15)
FAIRNESS_DISPARITY_THRESHOLD=0.15

# Number of heatmap samples to generate per analysis
HEATMAP_NUM_SAMPLES=6
