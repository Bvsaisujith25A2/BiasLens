# BiasLens Environment Variables
# Copy this file to .env.local and fill in the values

# Required: Base URL for the FastAPI backend
# Example: https://api.biaslens.example.com
NEXT_PUBLIC_API_BASE_URL=https://3.110.87.92.nip.io

# Optional: Polling configuration
NEXT_PUBLIC_POLLING_INTERVAL=5000
NEXT_PUBLIC_POLLING_MAX_ATTEMPTS=120

# Optional: File upload limits
NEXT_PUBLIC_MAX_FILE_SIZE_MB=500
